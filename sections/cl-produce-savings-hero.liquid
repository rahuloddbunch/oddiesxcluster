{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .cl-produce-savings-hero-grid {
        display: flex !important;
        flex-direction: column !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-text-item {
        order: 1;
        width: 100% !important;
        max-width: 100% !important;
        flex: 0 0 100% !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-text-item .image-with-text__content {
        align-items: center !important;
        justify-content: flex-start !important;
        height: auto !important;
        padding: 0 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-text-item .image-with-text__content > * {
        align-self: center !important;
        text-align: center !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-hero-heading {
        font-size: 3.6rem !important;
        line-height: 1.1 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-desktop-image-part {
        order: 2;
        display: block !important;
        width: 100% !important;
        max-width: 22rem !important;
        margin: 0 auto !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-desktop-image-part .spinner-wrap {
        width: 60px !important;
        height: 60px !important;
        top: 45px !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-delivered-text {
        margin: 0.9rem 0 0 !important;
        text-align: center !important;
        font-size: 3.6rem !important;
        line-height: 1.1 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-delivered-text--desktop {
        display: block !important;
        width: 100% !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-delivered-text--mobile {
        display: none !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-mobile-sec-image-part {
        display: none !important;
      }
    }

  @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .cl-produce-savings-hero-heading {
        text-align: center !important;
        font-size: 3.15rem !important;
        line-height: 1.1 !important;
      }

      #shopify-section-{{ section.id }} .image-with-text__content > .cl-produce-savings-mobile-sec-image-part {
        margin-top: 0 !important;
        padding-top: 0 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-delivered-text {
        margin: 0.75rem 0 0 !important;
        text-align: center !important;
        font-size: 2.68rem !important;
        line-height: 1.1 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-mobile-sec-image-part {
        display: block !important;
        max-width: 20rem !important;
        margin: 0 auto !important;
        position: relative !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-mobile-sec-image-part .spinner-wrap {
        width: 50px !important;
        height: 50px !important;
        top: 30px !important;
        right: 0 !important;
        left: auto !important;
        position: absolute !important;
        z-index: 9 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-text-item .image-with-text__content {
        align-items: center !important;
        height: auto !important;
        overflow: visible !important;
        padding: 0 !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-delivered-text--desktop {
        display: none !important;
      }

      #shopify-section-{{ section.id }} .cl-produce-savings-delivered-text--mobile {
        display: block !important;
        color: inherit !important;
      }
    }
{%- endstyle -%}

{%- liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
  if section.settings.color_scheme == section.settings.section_color_scheme and section.settings.content_layout == 'no-overlap'
    assign remove_color_classes = true
  endif
-%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width">
    <div class="title-sec-man">
       <h2
          class="image-with-text__heading inline-richtext h1{{ section.settings.heading_size }}"
          {{ block.shopify_attributes }}
        >
          {{ section.settings.heading2 }}
        </h2>
    </div>
    <div class="image-with-text image-with-text--{{ section.settings.content_layout }} isolate{% if settings.text_boxes_border_thickness > 0 and settings.text_boxes_border_opacity > 0 and settings.media_border_thickness > 0 and settings.media_border_opacity > 0 %} collapse-borders{% endif %}{% unless section.settings.color_scheme == section.settings.section_color_scheme and settings.media_border_thickness > 0 and settings.text_boxes_shadow_opacity == 0 and settings.text_boxes_border_thickness == 0 or settings.text_boxes_border_opacity == 0 %} collapse-corners{% endunless %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="image-with-text__grid grid grid--gapless grid--1-col grid--{% if section.settings.desktop_image_width == 'medium' %}2-col-tablet{% else %}3-col-tablet{% endif %}{% if section.settings.layout == 'text_first' %} image-with-text__grid--reverse{% endif %} cl-produce-savings-hero-grid">
        <div class="image-with-text__media-item desktop-sec-image-part image-with-text__media-item--{{ section.settings.desktop_image_width }} image-with-text__media-item--{{ section.settings.desktop_content_position }} grid__item cl-produce-savings-desktop-image-part">
          <div
            class="image-with-text__media image-with-text__media--{{ section.settings.height }} global-media-settings{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}{% if section.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}"
            {% if section.settings.height == 'adapt' and section.settings.image != blank %}
              style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
            {% endif %} data-aos="fade-up"
          >
            {%- if section.settings.image != blank -%}
              {%- if section.settings.image_behavior == 'ambient' or section.settings.image_behavior == 'zoom-in' -%}
                {%- assign widths = '198, 432, 642, 900, 1284, 1800' -%}
                {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 1.6667 }}px,
              (min-width: 750px) calc((100vw - 130px) / 1.667), calc((100vw - 50px) / 1.667)
            {%- endcapture -%}
              {%- else -%}
                {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
                {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
              (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
            {%- endcapture -%}
              {%- endif -%}
              {{
                section.settings.image
                | image_url: width: 1500
                | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
              }}
            {%- else -%}
              {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            <div class="spinner-wrap" title="Hover to pause">
            <img class="spin-img" src="https://cdn.shopify.com/s/files/1/0664/2404/5729/files/Badge.png?v=1756885365" alt="Rotating Round Image">
          </div>

          </div>
        </div>
        <div class="image-with-text__text-item grid__item cl-produce-savings-text-item" data-aos="fade-up">
          <div
            id="ImageWithText--{{ section.id }}"
            class="image-with-text__content image-with-text__content--{{ section.settings.desktop_content_position }} image-with-text__content--desktop-{{ section.settings.desktop_content_alignment }} image-with-text__content--mobile-{{ section.settings.mobile_content_alignment }} image-with-text__content--{{ section.settings.height }} content-container{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}"
          >
            <div class="text-sec-image-with-text-part">
              <div class="round-sec-image-part">
                <img class="people-img" src="https://cdn.shopify.com/s/files/1/0664/2404/5729/files/People.png?v=1757251520" alt="Oddies People">
              </div>
              <p>1000's of aussies fighting food waste and counting</p>
            </div>
            {%- for block in section.blocks -%}
              {% case block.type %}
                {%- when 'heading' -%}
                  <h2
                    class="image-with-text__heading inline-richtext {{ block.settings.heading_size }} cl-produce-savings-hero-heading"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.heading }}
                  </h2>
                {%- when 'caption' -%}
                {%- when 'text' -%}
                  <div class="image-with-text__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                  <div class="image-with-text__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text2 }}
                  </div>
                  <div class="image-with-text__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text3 }}
                  </div>
                  {%- when 'image' -%}
                  <div class="mobile-sec-image-part cl-produce-savings-mobile-sec-image-part">
                    <div
            class="image-with-text__media image-with-text__media--{{ section.settings.height }} global-media-settings{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}{% if section.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}"
            {% if section.settings.height == 'adapt' and section.settings.image != blank %}
              style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
            {% endif %}
          >
                  {%- if block.settings.image2 != blank -%}
                    {%- if section.settings.image_behavior == 'ambient' or section.settings.image_behavior == 'zoom-in' -%}
                      {%- assign widths = '198, 432, 642, 900, 1284, 1800' -%}
                      {%- capture sizes -%}
                    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 1.6667 }}px,
                    (min-width: 750px) calc((100vw - 130px) / 1.667), calc((100vw - 50px) / 1.667)
                  {%- endcapture -%}
                    {%- else -%}
                      {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
                      {%- capture sizes -%}
                    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                    (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                  {%- endcapture -%}
                    {%- endif -%}
                    {{
                      block.settings.image2
                      | image_url: width: 1500
                      | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                    }}
                  {%- else -%}
                    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                    
                  </div>
                  <div class="spinner-wrap test" title="Hover to pause">
                    <img class="spin-img" src="https://cdn.shopify.com/s/files/1/0664/2404/5729/files/Badge.png?v=1756885365" alt="Rotating Round Image">
                  </div>
                  <h2 class="image-with-text__heading inline-richtext h1 cl-produce-savings-delivered-text cl-produce-savings-delivered-text--mobile">Delivered weekly</h2>
                  </div>
                {%- when 'button' -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
    <h2 class="image-with-text__heading inline-richtext h1 cl-produce-savings-delivered-text cl-produce-savings-delivered-text--desktop">Delivered weekly</h2>
  </div>
</div>
{% comment %} <style>
  @media screen and (max-width: 767px) {
  .spinner-wrap.test {
    width: 80px;
    height: 80px;
    right: 0px;
    left: auto;
    top: 30px;
    z-index: 9;
    position: absolute;
}
.mobile-sec-image-part{position:relative;}
} {% endcomment %}
</style>

{% comment %} CLUSTER-AGENT START - Smooth scroll to product grid {% endcomment %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Find all anchor links in this section that point to #choose-your-box
    const scrollLinks = document.querySelectorAll('a[href="#choose-your-box"]');

    scrollLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        const targetId = 'choose-your-box';
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
          // Calculate position with offset to show "Our Boxes" heading at top with margin
          const offset = 120; // Enough space to show heading + top margin
          const elementPosition = targetElement.getBoundingClientRect().top + window.pageYOffset;
          const offsetPosition = elementPosition - offset;

          // Smooth scroll to position
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  });
</script>
{% comment %} CLUSTER-AGENT END {% endcomment %}

{% schema %}
{
